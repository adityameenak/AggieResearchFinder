# Copy to .env and fill in your values
# AI — leave blank to run in mock mode (no LLM calls)
ANTHROPIC_API_KEY=

# Database — defaults to local SQLite; swap for Postgres in prod
DATABASE_URL=sqlite:///./tamurf.db

# Frontend origin for CORS
CORS_ORIGINS=http://localhost:5173

# Uploaded files directory
UPLOAD_DIR=./uploads
